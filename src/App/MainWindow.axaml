<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Nexu.App.Controls"
        x:Class="Nexu.App.MainWindow"
        Title="Nexu — JSON Mind Map"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open JSON…" Click="OnOpenClick" />
                <MenuItem Header="_Save" Click="OnSaveClick" HotKey="Ctrl+S" />
            </MenuItem>
        </Menu>
        <Border DockPanel.Dock="Bottom"
                Background="#F1F5F9"
                BorderBrush="#CBD5E1"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <TextBlock x:Name="StatusBar"
                       FontSize="12"
                       Foreground="#64748B"
                       Text="Open a JSON file to get started." />
        </Border>
        <controls:CanvasHostControl x:Name="Canvas"
                                    ClipToBounds="True" />
    </DockPanel>
</Window>
